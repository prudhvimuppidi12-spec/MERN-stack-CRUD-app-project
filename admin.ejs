<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard - RailBook</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    body {
      background: #f4f6f9;
      font-family: 'Segoe UI', sans-serif;
    }

    .sidebar {
      height: 100vh;
      background: #212529;
      color: white;
      padding: 20px;
    }

    .sidebar h4 {
      margin-bottom: 30px;
    }

    .sidebar a {
      display: block;
      color: white;
      text-decoration: none;
      margin-bottom: 15px;
      padding: 8px;
      border-radius: 5px;
    }

    .sidebar a:hover {
      background: #343a40;
    }

    .card {
      border-radius: 15px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .table th {
      background: #0d6efd;
      color: white;
    }
  </style>
</head>

<body>

<div class="container-fluid">
  <div class="row">

    <!-- Sidebar -->
    <div class="col-md-2 sidebar">
      <h4>🚆🛤️ Admin Panel</h4>
      <a href="#addTrain"><i class="fas fa-plus-circle"></i> Add Train</a>
      <a href="#approveUsers"><i class="fas fa-user-check"></i> Approve Users</a>
      <a href="/"><i class="fas fa-home"></i> Home</a>
    </div>

    <!-- Main Content -->
    <div class="col-md-10 p-4">

      <!-- Add Train Section -->
      <div id="addTrain" class="card p-4 mb-4">
        <h4 class="mb-3"><i class="fas fa-train"></i> Add New Train</h4>

        <form method="POST" action="/addTrain">
          <div class="row">
            <div class="col-md-3">
              <input class="form-control mb-3" name="name" placeholder="Train Name" required>
            </div>
            <div class="col-md-3">
              <input class="form-control mb-3" name="source" placeholder="Source" required>
            </div>
            <div class="col-md-3">
              <input class="form-control mb-3" name="destination" placeholder="Destination" required>
            </div>
            <div class="col-md-2">
              <input class="form-control mb-3" name="availableSeats" type="number" placeholder="Seats" required>
            </div>
            <div class="col-md-1">
              <button class="btn btn-primary w-100">
                <i class="fas fa-plus"></i>
              </button>
            </div>
          </div>
        </form>
      </div>

      <!-- Approve Users Section -->
      <div id="approveUsers" class="card p-4">
        <h4 class="mb-3"><i class="fas fa-users"></i> Pending User Approvals</h4>

        <% if(users.length === 0){ %>
          <p class="text-muted">No users waiting for approval.</p>
        <% } else { %>

        <table class="table table-bordered table-hover">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Action</th>
          </tr>

          <% users.forEach(user=>{ %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td>
              <form method="POST" action="/approve/<%=user._id%>">
                <button class="btn btn-success btn-sm">
                  <i class="fas fa-check"></i> Approve
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
        </table>

        <% } %>
      </div>

    </div>
  </div>
</div>

</body>
</html>